{
  "name": "express-js-starter",
  "version": "1.0.0",
  "description": "Express + TypeScript API starter with Drizzle ORM, JWT auth, and Socket.IO",
  "main": "dist/src/index.js",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "echo \"Note: Build is not really needed for Bun, but keeping it for compatibility...\" && tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime": "^4.1.0",
    "multer": "^2.0.2",
    "postgres": "^3.4.3",
    "socket.io": "^4.7.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.0.3",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "express",
    "typescript",
    "drizzle",
    "postgresql",
    "socket.io",
    "jwt"
  ],
  "author": "",
  "license": "ISC"
}
